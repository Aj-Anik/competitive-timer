{
  "name": "competitive-timer",
  "displayName": "Competitive Timer",
  "description": "Timer for competitive programmers",
  "version": "0.0.2",
  "publisher": "ajanik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aj-Anik/competitive-timer"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },

  "categories": [
    "Other"
  ],

"activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",

"contributes": {
  "views": {
    "explorer": [
      {
        "id": "competitiveTimerView",
        "name": "Competitive Timer",
        "type": "webview"
      }
    ]
  }
},

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },

  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/node": "22.x",
    "typescript": "^5.9.3"
  }
}
